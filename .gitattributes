# Auto-normalize line endings (prevents the 10k changes nightmare)
* text=auto eol=lf

# Force specific files to LF (best for Python & data)
*.py    text eol=lf
*.md    text eol=lf
*.csv   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.db    binary

# Office / document binaries (very important!)
*.xlsx  binary
*.xls   binary
*.docx  binary
*.doc   binary
*.pptx  binary
*.ppt   binary
*.pdf   binary

# Other common binaries
*.parquet binary
*.feather binary
*.zip    binary
*.7z     binary

# Images (you already have png/jpg — make it complete)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary

# SVG should stay text
*.svg   text eol=lf

# Jupyter notebooks (they are JSON)
*.ipynb text eol=lf